# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# MODELSCOPE_API_KEY=xxx
# CLAUDE_CODE_OAUTH=xxx
# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# Feishu (飞书)
# PICOCLAW_CHANNELS_FEISHU_APP_ID=cli_xxx
# PICOCLAW_CHANNELS_FEISHU_APP_SECRET=xxx
# PICOCLAW_CHANNELS_FEISHU_RANDOM_REACTION_EMOJI=Typing,OneSecond

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── GitHub ────────────────────────────────
# Obter em: https://github.com/settings/tokens
# Permissões necessárias: repo, workflow, read:org
# GITHUB_TOKEN=ghp_xxx
# GIT_AUTHOR_NAME=Seu Nome
# GIT_AUTHOR_EMAIL=seu@email.com

# ── Deploy (Netlify) ──────────────────────
# Obter em: https://app.netlify.com/user/applications/personal
# NETLIFY_AUTH_TOKEN=nfp_xxx
# NETLIFY_SITE_ID=xxx   # opcional, ID do site padrão

# ── Timezone ──────────────────────────────
TZ=America/Sao_Paulo
